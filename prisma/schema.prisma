// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Batches {
  id                    String                 @id @default(uuid())
  starting_date         DateTime               @default(now())
  expected_selling_date DateTime
  initial_quantity      Int
  init_chicks_avg_wt    Float
  breed                 BirdBreeds
  batch_id              String                 @unique
  status                BatchStatus            @default(RUNNING)
  phase                 Phase
  farm_code             String
  product_code          String
  sector_code           String
  created_at            DateTime               @default(now())
  updated_at            DateTime               @updatedAt
  batchSuppliers        BatchSuppliers[]
  Environment           EnvironmentRecords[]
  Medications           Medications[]
  Vaccination           Vaccinations[]
  weightRecords         WeightRecords[]
  batchHouseAllocations BatchHouseAllocation[]
  events                HouseEvents[]
  expenses              Expense[]
  birdSales             BirdSale[]
  batchFeedingPrograms  BatchFeedingProgram[]
  consumptions          Consumption[]
  stockReservations     StockReservation[]

  @@index([farm_code, sector_code, product_code, batch_id])
}

model BatchSuppliers {
  id               String    @id @default(uuid())
  batch_id         String
  supplier_id      String
  price_per_chicks Decimal   @db.Decimal(10, 2)
  quantity         Int // number of chicks from this supplier
  delivery_date    DateTime
  batch            Batches   @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  supplier         Suppliers @relation(fields: [supplier_id], references: [id], onDelete: Cascade)

  @@unique([batch_id, supplier_id]) // one row per supplier per batch
}

model HouseEvents {
  id            String    @id @default(uuid())
  batch_id      String?
  house_id      String
  event_type    EventType
  quantity      Float
  unit          Units
  occurred_at   DateTime
  farm_date     DateTime  @db.Date
  created_by_id String
  batch         Batches?  @relation(fields: [batch_id], references: [id], onDelete: SetNull)
  house         Houses    @relation(fields: [house_id], references: [id], onDelete: Cascade)
  created_by    Profiles  @relation(fields: [created_by_id], references: [id], onDelete: Restrict)
}

model WeightRecords {
  id               String   @id @default(uuid())
  batch_id         String?
  batch            Batches? @relation(fields: [batch_id], references: [id], onDelete: SetNull)
  house_id         String
  house            Houses   @relation(fields: [house_id], references: [id], onDelete: Cascade)
  average_wt_grams Decimal  @db.Decimal(10, 2)
  sample_size      Int
  date             DateTime
  farm_date        DateTime @db.Date
  measured_by_id   String
  measured_by      Profiles @relation(fields: [measured_by_id], references: [id], onDelete: Cascade)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([batch_id, house_id, date])
}

model Houses {
  id         String    @id @default(uuid())
  name       String // custom name like "Brooder 3"
  type       HouseType
  number     Int
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  weightRecords    WeightRecords[]
  allocations_to   BatchHouseAllocation[] @relation("ToHouse")
  allocations_from BatchHouseAllocation[] @relation("FromHouse")
  events           HouseEvents[]

  consumptions Consumption[]

  stockReservations StockReservation[]

  houseFeedInventories HouseFeedInventory[]
}

model BatchHouseAllocation {
  id String @id @default(uuid())

  batch_id String
  batch    Batches @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  from_house_id String?
  from_house    Houses? @relation("FromHouse", fields: [from_house_id], references: [id], onDelete: SetNull)

  to_house_id String?
  to_house    Houses? @relation("ToHouse", fields: [to_house_id], references: [id], onDelete: Cascade)

  quantity Int // quantity moved in THIS event (always positive)

  reason      AllocationReason
  occurred_at DateTime         @default(now())

  created_at DateTime @default(now())

  @@index([batch_id])
  @@index([from_house_id])
  @@index([to_house_id])
}

model BatchHouseBalance {
  id       String @id @default(uuid())
  batch_id String
  house_id String
  quantity Int

  updated_at DateTime @updatedAt

  @@unique([batch_id, house_id])
  @@index([house_id])
  @@index([batch_id])
}

model Profiles {
  id            String          @id @default(uuid())
  email         String?         @unique
  name          String
  mobile        String
  address       String?
  avatar_id     String?
  role          UserRole
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  // online_contact ContactMethods[]
  avatar        Avatars?        @relation(fields: [avatar_id], references: [id], onDelete: SetNull)
  employees     Employees?
  admins        Admins?
  customers     Customers?
  suppliers     Suppliers?
  doctors       Doctors?
  houseEvents   HouseEvents[]
  weightRecords WeightRecords[]

  payments Payment[]

  houseFeedInventories HouseFeedInventory[]
}

model Employees {
  id           String            @id @default(uuid())
  profile_id   String            @unique
  profiles     Profiles          @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  salary       Float
  joining_date DateTime          @default(now())
  rating       Float?            @default(0)
  role         EmployeeRoleNames
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
}

model Admins {
  id          String         @id @default(uuid())
  profile_id  String         @unique
  profile     Profiles       @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  Medications Medications[]
  Vaccination Vaccinations[]
}

model Customers {
  id         String   @id @default(uuid())
  profile_id String   @unique
  profile    Profiles @relation(fields: [profile_id], references: [id])
  rating     Float?   @default(0)
  company    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  Sale       Sale[]

  birdSales BirdSale[]
}

model Suppliers {
  id             String                     @id @default(uuid())
  profile_id     String                     @unique
  profile        Profiles                   @relation(fields: [profile_id], references: [id])
  rating         Float?                     @default(0)
  role           SupplierRoleNames
  type           SupplierSupplyCategories[]
  company        String?
  created_at     DateTime                   @default(now())
  updated_at     DateTime                   @updatedAt
  Item           Item[]
  batchSuppliers BatchSuppliers[]

  purchases Purchase[]
}

model Doctors {
  id          String         @id @default(uuid())
  specialty   String?
  position    String?
  degrees     String[]
  rating      Float?         @default(0)
  sector      String?
  institution String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  profile_id  String         @unique
  profile     Profiles       @relation(fields: [profile_id], references: [id])
  Medications Medications[]
  Vaccination Vaccinations[]
}

model StockLedger {
  id String @id @default(uuid())

  item_id String
  item    Item   @relation(fields: [item_id], references: [id])

  quantity Decimal @db.Decimal(10, 3)

  location_type LocationType?
  location_id   String?

  reason      StockReason
  occurred_at DateTime    @default(now())

  unit_cost Decimal?       @db.Decimal(10, 2)
  direction StockDirection

  // tracing & safety
  ref_type        RefType
  ref_id          String
  idempotency_key String

  @@unique([idempotency_key])
  @@index([item_id, occurred_at])
  @@index([location_type, location_id])
  @@index([ref_type, ref_id])
}

model Consumption {
  id       String   @id @default(uuid())
  house_id String
  batch_id String?
  quantity Decimal  @db.Decimal(10, 3)
  item_id  String
  date     DateTime
  note     String?

  item       Item     @relation(fields: [item_id], references: [id])
  house      Houses   @relation(fields: [house_id], references: [id])
  batch      Batches? @relation(fields: [batch_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model StockReservation {
  id       String   @id @default(uuid())
  house_id String
  batch_id String?
  item_id  String
  quantity Decimal  @db.Decimal(10, 3)
  date     DateTime
  note     String?

  house      Houses   @relation(fields: [house_id], references: [id])
  item       Item     @relation(fields: [item_id], references: [id])
  batch      Batches? @relation(fields: [batch_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([item_id])
  @@index([house_id])
  @@index([batch_id])
}

model Item {
  id                    String             @id @default(uuid())
  name                  String
  normalized_key        String?
  category              ResourceCategories
  unit                  Units
  meta_data             Json
  reorder_level         Decimal?           @db.Decimal(10, 3)
  preferred_reorder_qty Decimal?           @db.Decimal(10, 3)
  lead_time_days        Int?
  updated_at            DateTime           @updatedAt
  created_at            DateTime           @default(now())
  ledger_entries        StockLedger[]
  suppliers             Suppliers[]
  saleItems             SaleItem[]

  purchaseItems        PurchaseItem[]
  batchFeedingPrograms BatchFeedingProgram[]
  itemOrganizations    ItemOrganization[]
  stockReservations    StockReservation[]
  consumptions         Consumption[]
  houseFeedInventories HouseFeedInventory[]

  @@index([name, category])
}

model Organization {
  id             String   @id @default(uuid())
  label_name     String // EXACT label text
  normalized_key String // cleaned for searching
  updated_at     DateTime @updatedAt
  created_at     DateTime @default(now())

  itemLinks ItemOrganization[]

  @@unique([normalized_key])
  @@index([normalized_key])
}

model ItemOrganization {
  id String @id @default(uuid())

  item_id         String
  organization_id String

  role OrganizationRole

  item         Item         @relation(fields: [item_id], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([item_id, organization_id, role])
}

model BatchFeedingProgram {
  id        String   @id @default(uuid())
  batch_id  String
  feed_type FeedType // STARTER, GROWER, FINISHER
  item_id   String
  start_day Int // Day of batch life
  end_day   Int?

  batch Batches @relation(fields: [batch_id], references: [id])
  item  Item    @relation(fields: [item_id], references: [id])

  @@index([batch_id, start_day, end_day])
}

model HouseFeedInventory {
  id                 String  @id @default(uuid())
  house_id           String
  item_id            String
  quantity_remaining Decimal @db.Decimal(10, 3)

  last_modified_by String
  updated_at       DateTime @updatedAt

  house   Houses   @relation(fields: [house_id], references: [id], onDelete: Cascade)
  item    Item     @relation(fields: [item_id], references: [id], onDelete: Cascade)
  profile Profiles @relation(fields: [last_modified_by], references: [id])

  @@unique([house_id, item_id])
}

model Sale {
  id         String     @id @default(uuid())
  customerId String?
  customer   Customers? @relation(fields: [customerId], references: [id])

  sale_date DateTime
  total     Decimal

  items SaleItem[]

  createdAt DateTime @default(now())
}

model BirdSale {
  id String @id @default(uuid())

  batch_id String
  batch    Batches @relation(fields: [batch_id], references: [id])

  customer_id String?
  customer    Customers? @relation(fields: [customer_id], references: [id])

  sale_date DateTime

  grade               BirdGrade // A, B, LOW, CULL
  male_count          Int?
  dholta_in_g         Decimal   @db.Decimal(10, 2)
  total_katha         Int
  avg_wt_per_katha_kg Decimal?  @db.Decimal(10, 2)
  female_count        Int?
  birds_count         Int
  avg_weight_g        Decimal?  @db.Decimal(10, 2) // optional
  total_weight        Decimal   @db.Decimal(10, 2)
  net_weight          Decimal   @db.Decimal(10, 2)
  price_per_kg        Decimal   @db.Decimal(10, 2)
  total_amount        Decimal   @db.Decimal(10, 2)

  created_at DateTime @default(now())
}

model SaleItem {
  id String @id @default(uuid())

  sale_id String
  sale    Sale   @relation(fields: [sale_id], references: [id])

  item_id String
  item    Item   @relation(fields: [item_id], references: [id])

  quantity    Decimal
  unit        Units
  unit_price  Decimal @db.Decimal(10, 2)
  total_price Decimal @db.Decimal(10, 2)

  @@index([sale_id])
  @@index([item_id])
}

model Expense {
  id       String          @id @default(uuid())
  batch_id String?
  category ExpenseCategory // LABOR, ELECTRICITY, TRANSPORT
  amount   Float
  date     DateTime
  remarks  String?

  batch Batches? @relation(fields: [batch_id], references: [id])
}

model Purchase {
  id          String    @id @default(uuid())
  supplier_id String
  supplier    Suppliers @relation(fields: [supplier_id], references: [id])

  invoice_no    String?
  purchase_date DateTime
  total_amount  Decimal  @db.Decimal(10, 2)
  paid_amount   Decimal  @db.Decimal(10, 2)
  due_amount    Decimal  @db.Decimal(10, 2)

  items PurchaseItem[]

  created_at DateTime @default(now())
}

model PurchaseItem {
  id String @id @default(uuid())

  purchase_id String
  purchase    Purchase @relation(fields: [purchase_id], references: [id])

  item_id String
  item    Item   @relation(fields: [item_id], references: [id])

  mfg_date        DateTime? // Manufacturing date
  expiration_date DateTime? // Add this field
  quantity        Decimal   @db.Decimal(10, 3)
  unit            Units
  unit_price      Decimal   @db.Decimal(10, 2)
  total_price     Decimal   @db.Decimal(10, 2)
  created_at      DateTime  @default(now())
}

model Payment {
  id String @id @default(uuid())

  amount       Decimal  @db.Decimal(10, 2)
  payment_date DateTime

  direction PaymentType // INCOMING / OUTGOING
  ref_type  PaymentRefType // SALE / BIRD_SALE / PURCHASE / EXPENSE
  ref_id    String

  // FROM where money moved
  from_instrument_id String
  from_instrument    PaymentInstrument @relation("PaymentFrom", fields: [from_instrument_id], references: [id])

  // TO where money moved
  to_instrument_id String
  to_instrument    PaymentInstrument @relation("PaymentTo", fields: [to_instrument_id], references: [id])

  transaction_ref String? // bank slip, bKash Txn ID (PER PAYMENT)

  handled_by_id String? // cashier / staff
  handled_by    Profiles? @relation(fields: [handled_by_id], references: [id])

  note String?

  created_at DateTime @default(now())

  @@index([ref_type, ref_id])
}

model PaymentInstrument {
  id String @id @default(uuid())

  owner_type UserRole // FARM / SUPPLIER / CUSTOMER
  owner_id   String

  type  PaymentMethod // CASH / BANK / MOBILE
  label String // "Farm bKash", "Rahman Bank A/C"

  bank_name  String?
  account_no String?
  mobile_no  String?
  mfs_type   MfsType?

  is_active Boolean @default(true)

  created_at DateTime @default(now())

  payments_from Payment[] @relation("PaymentFrom")
  payments_to   Payment[] @relation("PaymentTo")
}

model Medications {
  id                 String    @id @default(uuid())
  batch_id           String
  date               DateTime  @default(now())
  medication_details String
  administered_by    String
  medicine_name      String
  dosage             String
  cause              String?
  period             String?
  doctor_id          String?
  remarks            String?
  farm_date          DateTime? @db.Date
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  administered       Admins    @relation(fields: [administered_by], references: [id])
  batch              Batches   @relation(fields: [batch_id], references: [id])
  doctor             Doctors?  @relation(fields: [doctor_id], references: [id])
}

model Vaccinations {
  id              String    @id @default(uuid())
  batch_id        String
  date            DateTime  @default(now())
  vaccine_details String?
  administered_by String
  vaccine_name    String
  dosage          Int
  cause           String?
  period          String?
  doctor_id       String?
  remarks         String?
  farm_date       DateTime? @db.Date
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  administered    Admins    @relation(fields: [administered_by], references: [id])
  batch           Batches   @relation(fields: [batch_id], references: [id])
  doctor          Doctors?  @relation(fields: [doctor_id], references: [id])
}

model EnvironmentRecords {
  id               String      @id @default(uuid())
  batch_id         String
  house_no         Int
  temperature_c    Float
  humidity_percent Float
  ammonia_ppm      Float
  co2_ppm          Float
  air_pressure_hpa Float
  farm_date        DateTime?   @db.Date
  time_period      TimePeriods
  recorded_at      DateTime    @default(now())
  batch            Batches     @relation(fields: [batch_id], references: [id])
}

model Avatars {
  id         String     @id @default(uuid())
  public_id  String
  image_url  String
  created_at DateTime   @default(now())
  profiles   Profiles[]
}

model Alerts {
  id          String            @id @default(uuid())
  title       String
  description String?
  type        AlertTypes // e.g. "employee", "batch", "finance"
  level       AlertLevels // e.g. "info" | "warning" | "critical"
  status      AlertStatus       @default(ACTIVE) // active | resolved
  related_id  String? // link to employee_id, batch_id, etc.
  action_type AlertActionTypes? // pay | assign | mark_resolved etc.
  created_at  DateTime          @default(now())
  issued_at   DateTime?         @db.Date
  resolved_at DateTime?         @db.Date
}

enum EmployeeRoleNames {
  MANAGER
  WORKER
  INTERN
}

enum ContactMethods {
  WHATSAPP
  EMAIL
  IMO
  TELEGRAM
}

enum SupplierRoleNames {
  SALES_MAN
  OWNER
  DISTRIBUTOR
  DEALER
  WHOLESALER
  RETAILER
  MANUFACTURER
  IMPORTER
  REPRESENTATIVE
}

enum TransactionTypes {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
}

enum Units {
  BIRD
  KG
  LITER
  BAG
  BOX
  UNIT
  SACHETS
  BOTTLE
  MON
  TON
  ML
  L
  G
  PCS
  VIAL
  DOSE
  OTHER
}

enum TimePeriods {
  MORNING
  NOON
  AFTERNOON
  EVENING
  NIGHT
  MIDNIGHT
  LATENIGHT
}

enum BirdBreeds {
  CLASSIC
  HIBREED
  PAKISTHANI
  KEDERNATH
  FAOMI
  TIGER
}

enum ResourceCategories {
  FEED
  MEDICINE
  SUPPLEMENT
  BIOSECURITY
  VACCINE
  CHICKS
  HUSK
  EQUIPMENT
  UTILITIES
  SALARY
  TRANSPORTATION
  MAINTENANCE
  CLEANING_SUPPLIES
  OTHER
}

enum SupplierSupplyCategories {
  FEED
  MEDICINE
  CHICKS
  HUSK
  EQUIPMENT
  UTILITIES
  TRANSPORTATION
  CLEANING_SUPPLIES
  OFFICE_SUPPLIES
  SOFTWARE
  OTHER
}

enum AlertTypes {
  EMPLOYEE
  BATCH
  FEED
  MEDICINE
  SYSTEM
}

enum AlertLevels {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  RESOLVED
}

enum AlertActionTypes {
  PAY
  REASSIGN
  MARK_RESOLVED
}

enum HouseType {
  BROODER
  GROWER
}

enum BatchStatus {
  RUNNING
  CLOSED
  SOLD
}

enum Phase {
  BROODER
  GROWER
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CUSTOMER
  SUPPLIER
  DOCTOR
}

enum EventType {
  FEED
  WATER
  MORTALITY
}

enum ExpenseCategory {
  LABOR
  ELECTRICITY
  TRANSPORT
  INTERNET
}

enum RefType {
  HOUSE_EVENT
  STOCK_RESERVATION
  EXISTING_STOCK
  CONSUMPTION
  SALE
  PURCHASE
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum BirdGrade {
  HIGH
  LOW
  CULL
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MFS
}

enum MfsType {
  BKASH
  NAGAD
  ROCKET
}

enum PaymentType {
  INCOMING
  OUTGOING
}

enum PaymentRefType {
  SALE
  BIRD_SALE
  PURCHASE
  EXPENSE
}

enum StockDirection {
  IN
  OUT
}

enum LocationType {
  WAREHOUSE
  HOUSE
  CUSTOMER
  DISPOSAL
}

enum StockReason {
  PURCHASE
  TRANSFER
  CONSUMPTION
  SALE
  WASTAGE
  EXPIRED
  RETURN
  ADJUSTMENT
  OPENING_BALANCE
}

enum FeedType {
  PRE_STARTER
  STARTER
  GROWER
  FINISHER
  LAYER
}

enum AllocationReason {
  INITIAL // purchase → house
  TRANSFER // house → house
  ADJUSTMENT // correction (admin-only)
}

enum OrganizationRole {
  MANUFACTURER
  IMPORTER
  MARKETER
  DISTRIBUTOR
}
